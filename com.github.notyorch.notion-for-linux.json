{
  "app-id": "com.github.notyorch.notion-for-linux",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "notion-for-linux",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--share=network",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "notion-for-linux",
      "buildsystem": "simple",
      "build-commands": [
        "install -D notion-for-linux-1.1.0-x64.AppImage /app/bin/notion-for-linux",
        "chmod +x /app/bin/notion-for-linux",
        "install -D notion-for-linux.desktop /app/share/applications/com.github.notyorch.notion-for-linux.desktop",
        "install -D notion-icon.png /app/share/icons/hicolor/256x256/apps/com.github.notyorch.notion-for-linux.png"
      ],
      "sources": [
        {
          "type": "file",
          "url": "file://@APPIMAGE_PATH@",
          "sha256": "6dd1bd80a2c89b261b00e80e64f5d50ec8dd8ba5eba7a10abc3832524d9409d5",
          "dest-filename": "notion-for-linux-1.1.0-x64.AppImage"
        },
        {
          "type": "file",
          "url": "file://@DESKTOP_PATH@",
          "sha256": "2ffcbc2dfffa2fe54ecd557d07be2890d3e94d682770688b87a096d6a9d146cd",
          "dest-filename": "notion-for-linux.desktop"
        },
        {
          "type": "file",
          "url": "file://@ICON_PATH@",
          "sha256": "a92189a881568c0a81186e7ef26807155e906127d6011b052aea54176882a684",
          "dest-filename": "notion-icon.png"
        }
      ]
    }
  ]
}
